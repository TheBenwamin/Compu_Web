name: CI/CD Pipeline

# Se dispara en cada push a main y en cada Pull Request hacia main
on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

env:
  REGISTRY: ghcr.io
  # github.repository = "usuario/mi-app-web" -> lo pasamos a minúsculas más abajo
  IMAGE_NAME: ${{ github.repository }}

jobs:
  # ─────────────────────────────────────────────
  # 1. TEST — instala dependencias y corre Jest
  # ─────────────────────────────────────────────
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version: "20"
          cache: "npm"
      - run: npm ci
      - run: npm test

  # ─────────────────────────────────────────────
  # 2. DOCKER — build y push de la imagen a GHCR
  # ─────────────────────────────────────────────
  docker:
    needs: test
    runs-on: ubuntu-latest
    # Solo publicamos la imagen en pushes a main (no en PRs)
    if: github.event_name == 'push'
    permissions:
      contents: read
      packages: write
    outputs:
      image: ${{ steps.meta.outputs.image }}
    steps:
      - uses: actions/checkout@v4

      # Login en GitHub Container Registry usando el token automático del repo
      - uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      # GHCR exige el nombre en minúsculas; lo calculamos aquí
      - name: Calcular nombre de imagen
        id: meta
        run: |
          IMAGE=$(echo "${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}" | tr '[:upper:]' '[:lower:]')
          echo "image=$IMAGE" >> "$GITHUB_OUTPUT"

      - name: Build y push
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: |
            ${{ steps.meta.outputs.image }}:${{ github.sha }}
            ${{ steps.meta.outputs.image }}:latest
          cache-from: type=gha
          cache-to: type=gha,mode=max

  # ─────────────────────────────────────────────
  # 3. DEPLOY — crea un clúster kind efímero y despliega
  #    (deploy REAL, sin necesidad de cloud ni secrets externos)
  # ─────────────────────────────────────────────
  deploy:
    needs: docker
    runs-on: ubuntu-latest
    if: github.event_name == 'push'
    steps:
      - uses: actions/checkout@v4

      # Levanta un clúster de Kubernetes dentro del runner usando kind
      - name: Crear clúster kind
        uses: helm/kind-action@v1
        with:
          cluster_name: ci-cluster

      - name: Verificar clúster
        run: kubectl cluster-info && kubectl get nodes

      # Sustituimos el placeholder de la imagen por la imagen recién publicada
      - name: Inyectar imagen en el deployment
        run: |
          IMAGE=$(echo "${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}" | tr '[:upper:]' '[:lower:]')
          sed -i "s|ghcr.io/OWNER/mi-app-web:latest|${IMAGE}:${{ github.sha }}|g" k8s/deployment.yaml
          echo "Imagen a desplegar: ${IMAGE}:${{ github.sha }}"

      - name: Aplicar manifiestos
        run: |
          kubectl apply -f k8s/configmap.yaml
          kubectl apply -f k8s/deployment.yaml
          kubectl apply -f k8s/service.yaml

      - name: Esperar el rollout
        run: kubectl rollout status deployment/mi-app --timeout=120s

      - name: Estado final del clúster
        run: |
          kubectl get pods -o wide
          kubectl get svc
